APP_NAME="CodeBlue 365 Tenant Manager"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=codeblue365
DB_USERNAME=postgres
DB_PASSWORD=

BROADCAST_CONNECTION=log
CACHE_STORE=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=database
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Entra ID / OIDC Authentication
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_ALLOWED_TENANT_IDS=
ENTRA_ISSUER_PREFIX=https://login.microsoftonline.com/
ENTRA_EXPECTED_NONCE=
ENTRA_GROUP_ROLE_MAP_JSON={}

# Microsoft Graph API
GRAPH_RETRY_MAX_ATTEMPTS=3
GRAPH_RETRY_DELAY_MS=200

VITE_APP_NAME="${APP_NAME}"
